# Option A: place Google OAuth JSON at secrets/google-oauth-client.json
# (next.config.mjs loads client_id / client_secret automatically)
#
# Option B: set env vars directly (overrides secrets file)
#
# Google Cloud Console → APIs & Services → Credentials
# → OAuth 2.0 Client ID (Web) → Authorized JavaScript origins:
#   http://localhost:3000
#   https://linkto.nxnl.app
# (슬래시 없이, 포트 포함. 127.0.0.1 로 접속하면 localhost 와 별도 등록 필요)
#
# origin_mismatch 오류 = 위 목록에 현재 브라우저 주소창 origin 이 없을 때 발생

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

NEXT_PUBLIC_APP_URL=https://linkto.nxnl.app
NEXT_PUBLIC_API_URL=

# /admin 개발자 전용 접근 (Google 로그인 이메일, 쉼표로 여러 개 가능)
DEVELOPER_EMAILS=you@example.com

# SQLite path (default: data/linkto.db)
# LINKTO_DB_PATH=/home/ubuntu/linkto/data/linkto.db
